;; Manual overrides for the codegen pipeline.
;;
;; Two roles:
;;
;; 1. Skip lists. Methods/classes that are wrapped by hand in API.java
;;    (because they have irregular shape, optional args, stateful builders,
;;    or throw checked exceptions that need translation). The generator
;;    skips these and emits `// bespoke:` markers pointing at the hand-
;;    written sections.
;;
;; 2. Generic hints. Optional metadata that reflection can't recover
;;    (erased generic element types, semantic role like :predicate vs
;;    :measurement). Merged over the reflected entry by the classifier.
;;
;; Schema:
;;   {<fully-qualified-class-symbol>
;;    ;; Either :all to skip the entire class, or a set of method names.
;;    <:all | #{"method-name" ...}>}
;;
;; Generic hints live under :hints with the same key shape as registry.edn.

{:skip
 {

  ;; Common skip rationales (used by many entries below — not repeated per-class):
  ;;   - java.lang.Object payload: methods taking or returning java.lang.Object are
  ;;     irreducible at the JS boundary (no generic ser/de path).
  ;;   - JTS-internal types (DCEL, planargraph, index nodes, visitors): user-facing
  ;;     APIs route through wrapping containers; the internals aren't useful in JS.
  ;;   - java.awt.* / awt-adjacent: AWT bridge, unreachable from a JS runtime.
  ;;   - Java interface params (Comparable, Throwable, etc.): JS can't supply these.

  ;; Wholesale package skips. Match any class whose FQN starts with the
  ;; prefix followed by `.`. Used for fully-internal packages that have
  ;; no user-facing API surface — every entry would otherwise reach
  ;; classify-shape's :uncategorized fallback. Class-keyed entries take
  ;; precedence over these (currently unused; reserved for carve-outs).
  ;;
  ;; - geomgraph: DCEL primitives (Edge / EdgeEnd / Label / Node / DirectedEdge)
  ;;   plus the GeometryGraph builder consumed by OverlayOp/RelateOp/IsValidOp.
  ;;   The user-facing operations route through OverlayNGRobust / RelateOp;
  ;;   the DCEL classes themselves are noise. Removes ~302 :uncategorized.
  ;; - planargraph: edge/node primitives backing LineMerger / Polygonizer.
  ;;   The user-facing wrappers (LineMerger.getMergedLineStrings,
  ;;   Polygonizer.getPolygons) hide them entirely. Removes ~84 :uncategorized.
  ;; - noding: noding pipeline internals (SegmentString / NodingValidator /
  ;;   IntersectionAdder, etc.). User-facing operations route through
  ;;   OverlayNGRobust. The three classes whose static helpers are
  ;;   genuinely JS-callable (IteratedNoder.MAX_ITER constant; Octant
  ;;   and SegmentPointComparator pure-math helpers exercised by the
  ;;   differential test suite) carve out via :keep below. Removes ~183
  ;;   :uncategorized.
  ;; - index.bintree: bin-tree internals (Interval / Key / NodeBase /
  ;;   Root). Only Bintree itself is user-callable. Removes ~37.
  ;; - index.chain: monotone-chain internals (MonotoneChain /
  ;;   MonotoneChainBuilder). The Action callback interfaces stay
  ;;   (MonotoneChainOverlapAction / SelectAction). Removes ~16.
  ;; - index.sweepline: sweep-line internals (just the SweepLineOverlapAction
  ;;   callback class). The three user-facing classes (SweepLineEvent
  ;;   constant, SweepLineIndex, SweepLineInterval) carve out via :keep.
  ;;   Removes 1.
  "org.locationtech.jts.geomgraph"        :all
  "org.locationtech.jts.index.bintree"    :all
  "org.locationtech.jts.index.chain"      :all
  "org.locationtech.jts.index.sweepline"  :all
  "org.locationtech.jts.noding"           :all
  "org.locationtech.jts.planargraph"      :all

  ;; Carve-outs from the package-prefix skips above. The class-level
  ;; :keep sentinel exempts the class from any matching package skip,
  ;; so its methods classify normally. Each class here has at least
  ;; one in-scope template entry that would otherwise be lost to the
  ;; package skip. Classes whose existing skip-set (further down in
  ;; this map) already lists specific methods don't need :keep — any
  ;; class-keyed entry is definitive over the package-prefix wildcard
  ;; under skip?'s precedence rule.
  org.locationtech.jts.index.sweepline.SweepLineEvent              :keep
  org.locationtech.jts.noding.IteratedNoder                        :keep
  org.locationtech.jts.noding.Octant                               :keep
  org.locationtech.jts.noding.SegmentPointComparator               :keep

  ;; JTSVersion: instance-method version accessors on a singleton held by
  ;; the static-final JTSVersion.CURRENT_VERSION field. field-bearing-
  ;; classes today only handles int/char fields (Dimension constants);
  ;; exposing JTSVersion would need either string/object field support
  ;; or a bespoke wasmts.jts.version exporter. main(String[]) is a JVM
  ;; entry point. toString is an Object override.
  org.locationtech.jts.JTSVersion :all

  ;; CGAlgorithmsDD.signOfDet2x2: DD param not in coercible-param-types;
  ;; the wrapped-classes universe lifts DD as a return target but params
  ;; require an explicit extract<DD> case in coerce-arg-expr.
  org.locationtech.jts.algorithm.CGAlgorithmsDD
  #{["signOfDet2x2" ["org.locationtech.jts.math.DD"
                      "org.locationtech.jts.math.DD"
                      "org.locationtech.jts.math.DD"
                      "org.locationtech.jts.math.DD"]]}

  ;; HCoordinate: all 5 remaining methods declare `throws
  ;; NotRepresentableException` (division-by-zero for the homogeneous
  ;; intersection). The no-checked-throws? filter rejects these from
  ;; auto-classify; the bespoke-classify-overrides mechanism (used by
  ;; WKTReader.read's ParseException) doesn't have a translator wired
  ;; for NotRepresentableException yet. The .normalize() / coordinate
  ;; constructors already classify.
  org.locationtech.jts.algorithm.HCoordinate
  #{["<init>" ["org.locationtech.jts.algorithm.HCoordinate"
               "org.locationtech.jts.algorithm.HCoordinate"]]
    ["getCoordinate" []]
    ["getX" []]
    ["getY" []]
    ["intersection" ["org.locationtech.jts.geom.Coordinate"
                     "org.locationtech.jts.geom.Coordinate"
                     "org.locationtech.jts.geom.Coordinate"
                     "org.locationtech.jts.geom.Coordinate"]]}

  ;; LineIntersector: no-arg ctor on an abstract class -- concrete-class?
  ;; filter rejects abstracts. Users construct via RobustLineIntersector
  ;; (already auto-ctor'd in Tier 2).
  org.locationtech.jts.algorithm.LineIntersector
  #{["<init>" []]}

  ;; MinimumAreaRectangle ctors. The static getMinimumRectangle(Geometry)
  ;; convenience (already in :static-only-methods below) covers the use
  ;; case; the ctors expose an instance API with no exposed instance
  ;; methods, so wrapping them serves nothing.
  org.locationtech.jts.algorithm.MinimumAreaRectangle
  #{["<init>" ["org.locationtech.jts.geom.Geometry"]]
    ["<init>" ["org.locationtech.jts.geom.Geometry" "boolean"]]}


  ;; MinimumBoundingCircle.getExtremalPoints -> Coordinate[]. The Coordinate[]
  ;; return shape lacks an `:mbc->coordarray` defmethod. 70+ other uncategorized
  ;; entries across the registry share this return shape, so a one-off shape
  ;; here would be churn; deferred to Round 4 when the coordarray-returning
  ;; methods get a unified pass.
  org.locationtech.jts.algorithm.MinimumBoundingCircle #{"getExtremalPoints"}

  ;; PointLocator: BoundaryNodeRule param (no extract<BoundaryNodeRule>
  ;; mapping yet). The no-arg ctor uses the OGC_SFS default and is in
  ;; scope.
  org.locationtech.jts.algorithm.PointLocator
  #{["<init>" ["org.locationtech.jts.algorithm.BoundaryNodeRule"]]}
  ;; PolygonNodeTopology: compareAngle / isInteriorSegment
  ;; throw IllegalArgumentException on degenerate (0,0) inputs that the
  ;; property-test generator regularly hits. Other PolygonNodeTopology
  ;; methods stay in scope; just these two are excluded from auto-gen
  ;; until the generator learns to avoid zero-length coordinates (or the
  ;; differential harness treats matching-exceptions as a pass).
  org.locationtech.jts.algorithm.PolygonNodeTopology
  #{"compareAngle" "isInteriorSegment"}

  ;; setMaximum(PPD) / setMinimum(PPD) are duplicated by the
  ;; (Coordinate, Coordinate) overloads already in scope. Exposing the
  ;; PPD-taking variant would require PPD itself to be a coercible
  ;; param type; the Coordinate-pair form is the user-friendly API.
  org.locationtech.jts.algorithm.distance.PointPairDistance
  #{["setMaximum" ["org.locationtech.jts.algorithm.distance.PointPairDistance"]]
    ["setMinimum" ["org.locationtech.jts.algorithm.distance.PointPairDistance"]]}

   org.locationtech.jts.awt.FontGlyphReader
  #{
    ["read" ["java.lang.String" "java.awt.Font" "org.locationtech.jts.geom.GeometryFactory"]]
    ["read" ["java.lang.String" "java.awt.Font" "double" "org.locationtech.jts.geom.GeometryFactory"]]
    }

   org.locationtech.jts.awt.GeometryCollectionShape
  #{
    ["add" ["java.awt.Shape"]]
    ["contains" ["java.awt.geom.Point2D"]]
    ["contains" ["java.awt.geom.Rectangle2D"]]
    ["getBounds" []]
    ["getBounds2D" []]
