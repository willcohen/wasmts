 :static-only-methods
 ;; Class symbol -> #{method-name} | #{[method-name params-vec]}.
 ;; Per-method opt-in for static methods on value-type classes (Triangle,
 ;; LineSegment) that aren't on the static-utility-classes whitelist.
 ;; Without this, only the instance receiver shapes pick up; the parallel
 ;; statics stay :uncategorized.
 ;;
 ;; A classified entry still has to dodge a JS-path collision with any
 ;; instance variant. Entries here without a corresponding :hints :js-path
 ;; either need to be on a method with no instance counterpart
 ;; (Triangle.angleBisector) or accept that dedup-by-path will drop one.
 {
  ;; MinimumAreaRectangle.getMinimumRectangle(Geometry): static convenience
  ;; that constructs and runs the algorithm in one call. No instance variant
  ;; of the same name, so no :js-path hint is needed.
  org.locationtech.jts.algorithm.MinimumAreaRectangle #{"getMinimumRectangle"}

  ;; MinimumDiameter parallel statics. Both collide with same-named instance
  ;; methods on the no-arg side; :hints :js-path entries route the statics
  ;; to ...Static suffixes (mirrors Triangle.areaStatic / .centroidStatic).
  org.locationtech.jts.algorithm.MinimumDiameter
  #{["getMinimumRectangle" ["org.locationtech.jts.geom.Geometry"]]
    ["getMinimumDiameter" ["org.locationtech.jts.geom.Geometry"]]}

  ;; CoverageUnion.union(Geometry[]): JTS-recommended entry point for
  ;; unioning a polygonal coverage. Class isn't in :static-utility-classes
  ;; (private ctor + one static), so opt-in here. No JS-path collision.
  org.locationtech.jts.coverage.CoverageUnion #{"union"}

  ;; Densifier.densify(Geometry, double): JTS-recommended one-shot for
  ;; densifying a geometry without managing the instance/builder state.
  ;; Class isn't in :static-utility-classes (mixes instance setters with
  ;; the static convenience), so opt-in here. No JS-path collision with
  ;; the instance methods (setDistanceTolerance / setValidate /
  ;; getResultGeometry classify on different names).
  org.locationtech.jts.densify.Densifier #{"densify"}

  ;; Envelope static intersects predicates. The 3-Coord (point-in-segment-
  ;; bbox) and 4-Coord (segment-vs-segment-bbox) forms collide with the
  ;; same-named Envelope instance .intersects(...) variants on the default
  ;; wasmts.geom.Envelope.intersects path; :hints route them to
  ;; intersectsTriangle / intersectsQuad.
  org.locationtech.jts.geom.Envelope
  #{["intersects" ["org.locationtech.jts.geom.Coordinate"
                   "org.locationtech.jts.geom.Coordinate"
                   "org.locationtech.jts.geom.Coordinate"]]
    ["intersects" ["org.locationtech.jts.geom.Coordinate"
                   "org.locationtech.jts.geom.Coordinate"
                   "org.locationtech.jts.geom.Coordinate"
                   "org.locationtech.jts.geom.Coordinate"]]}

  ;; IntersectionMatrix.isTrue(int) tests whether a dimension value
  ;; represents a non-empty intersection. The bespoke @JS constructor for
  ;; IntersectionMatrix in API.java keeps its function-object form; the
  ;; auto-gen register pass installs .isTrue as a property on that function
  ;; object (JS allows static props on functions). No path collision.
  org.locationtech.jts.geom.IntersectionMatrix
  #{"isTrue" ["matches" ["int" "char"]]}

  ;; LineSegment.midPoint static collides with the instance variant; the
  ;; :hints :js-path entry puts the static at midPointStatic.
  org.locationtech.jts.geom.LineSegment #{"midPoint"}

  ;; PrecisionModel.mostPrecise(PM, PM) static. PM isn't in
  ;; static-utility-classes (it's a wrapped class with instance API);
  ;; per-method opt-in via :static-pm*pm->pm shape.
  org.locationtech.jts.geom.PrecisionModel #{"mostPrecise"}

  ;; Triangle statics. angleBisector / circumcentreDD / intersects have no
  ;; instance counterpart so they keep the default JS path; the rest
  ;; collide with same-named instance methods and rely on :hints :js-path
  ;; entries (areaStatic, centroidStatic, etc.).
  org.locationtech.jts.geom.Triangle
  #{"angleBisector" "area" "area3D" "centroid" "circumcentre"
    "circumcentreDD" "circumradius" "inCentre" "interpolateZ"
    "intersects" "isAcute" "isCCW" "length" "longestSideLength"
    "signedArea"}

  ;; PreparedGeometryFactory.prepare(Geometry): JTS-recommended static
  ;; entry for constructing a PreparedGeometry. Instance .create(Geometry)
  ;; on a factory handle exists but the JS surface uses the static. No
  ;; JS-path collision.
  org.locationtech.jts.geom.prep.PreparedGeometryFactory #{"prepare"}

  ;; GeometryFixer.fix has two static arities — (Geometry) and
  ;; (Geometry, boolean) for keepMulti. Both opt in here; the 2-arg
  ;; variant gets a :hints :js-path entry below (fixKeepMulti) so
  ;; dedup-by-path doesn't drop one of them. Instance ctor + setters +
  ;; getResult classify independently.
  org.locationtech.jts.geom.util.GeometryFixer #{"fix"}

  ;; Vector3D parallel statics: create / dot / length / normalize. Each has
  ;; a corresponding instance variant; matching :hints :js-path entries
  ;; keep them at distinct JS paths so dedup doesn't drop either side.
  org.locationtech.jts.math.Vector3D #{"create" "dot" "length" "normalize"}

  ;; BufferParameters.bufferDistanceError(int) static utility.
  org.locationtech.jts.operation.buffer.BufferParameters #{"bufferDistanceError"}

  ;; CascadedPolygonUnion.union(Collection<Geometry>): JTS static entry
  ;; point. Classifies as :static-collection->geom; dispatch wraps the JS
  ;; array via Arrays.asList(extractGeometryArray(...)). The instance side
  ;; (private ctor + private internals) stays out of scope.
  org.locationtech.jts.operation.union.CascadedPolygonUnion #{"union"}

  ;; GeometryPrecisionReducer parallel statics: reduce / reduceKeepCollapsed /
  ;; reducePointwise. Each takes (Geometry, PrecisionModel) and rounds
  ;; coordinates per the model's scale. The instance reduce(Geometry)
  ;; collides on .reduce with the static; a :hints :js-path below pins
  ;; the instance to .reduceInstance. The other two statics have no
  ;; instance counterpart so they keep the default JS path.
  org.locationtech.jts.precision.GeometryPrecisionReducer
  #{"reduce"            ; static reduce(Geometry, PrecisionModel)
    "reduceKeepCollapsed" "reducePointwise"}

  ;; DouglasPeuckerSimplifier.simplify(Geometry, double): static one-shot
  ;; (instance/builder side :skip-listed above). Classifies as
  ;; :static-geom*double->geom; installs at the canonical
  ;; wasmts.simplify.DouglasPeuckerSimplifier.simplify path matching the
  ;; previously hand-written export. No JS-path collision.
  org.locationtech.jts.simplify.DouglasPeuckerSimplifier #{"simplify"}}

 :extra-dts
 ;; Map from JS path -> raw TS signature for bespoke @JS exports that aren't
 ;; in the registry, or whose runtime contract is incompatible with what
 ;; auto-gen would emit. Injected as synthetic leaves in emit_dts's
 ;; functional path tree; do NOT appear on any OO interface.
 {
  ;; wasmts-specific helper (no JTS counterpart): rewrites a geometry's
  ;; coordinates from a flat numeric array. Lives bespoke in API.java
  ;; because no JTS method has this signature; the d.ts only needs the
  ;; type declaration to surface it to TS consumers.
  "wasmts.geom.applyCoordinates"
  "applyCoordinates(geometry: Geometry, coords: Float64Array | number[], stride: number): Geometry;"

  ;; Geometry.getCoordinates() returns [{x, y, z?, m?}, ...] plain JS objects
  ;; in this codebase (not wrapped Coordinate handles), for fast iteration in
  ;; JS hot loops. The TS interface `Coordinate` is a branded opaque handle
  ;; (no x/y properties), so declaring the return as `Coordinate[]` would
  ;; force `as unknown as Coordinate[]` casts to read .x/.y. The
  ;; :geom->coordarray dispatch emits the plain-object array via
  ;; API.coordsToPlainArrayJS.
  "wasmts.geom.getCoordinates"
  "getCoordinates(geometry: Geometry): { x: number; y: number; z?: number; m?: number }[];"}

