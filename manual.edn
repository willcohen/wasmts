   org.locationtech.jts.awt.ShapeWriter
  #{
    ["<init>" ["org.locationtech.jts.awt.PointTransformation"]]
    ["<init>" ["org.locationtech.jts.awt.PointTransformation" "org.locationtech.jts.awt.PointShapeFactory"]]
    ["toShape" ["org.locationtech.jts.geom.Geometry"]]
    }


  ;; coverage: all 5 CoverageSimplifier static + instance
  ;; simplify variants take double[] or Geometry[] in non-coercible
  ;; combinations (double[] not in coercible-param-types; Geometry[]
