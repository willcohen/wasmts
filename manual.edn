  org.locationtech.jts.operation.distance3d.Distance3DOp #{"nearestPoints"}

  ;; (Intersection.intersection/lineSegment and CGAlgorithmsDD.intersection
  ;; on collinear/parallel coordinate quads used to live here: JTS returns
