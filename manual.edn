  ;; ctor takes Collection<PointShape>-ish param; no JS use case.
   org.locationtech.jts.awt.PolygonShape
  #{
    ["<init>" ["org.locationtech.jts.geom.Coordinate[]" "java.util.Collection"]]
    ["contains" ["java.awt.geom.Rectangle2D"]]
    ["contains" ["java.awt.geom.Point2D"]]
    ["getBounds" []]
    ["getBounds2D" []]
    ["getPathIterator" ["java.awt.geom.AffineTransform"]]
    ["getPathIterator" ["java.awt.geom.AffineTransform" "double"]]
    ["intersects" ["java.awt.geom.Rectangle2D"]]
