  ;; TrianglePredicate.isInCircleCC (Cartesian-Cartesian, the basic
  ;; form) and isInCircleNonRobust are JTS's explicitly non-robust
  ;; implementations. They disagree with the robust variants on
  ;; near-collinear / numerically-eccentric triangles even within JTS
  ;; itself; differential-testing them against the JS port adds no
  ;; signal beyond rediscovering that non-robust predicates are non-
  ;; robust. The six robust/normalized/DD variants stay in coverage.
  org.locationtech.jts.triangulate.quadedge.TrianglePredicate
  #{"isInCircleCC" "isInCircleNonRobust"}

  ;; InteriorPointLine.getInteriorPoint picks the line vertex whose X
  ;; ordinate is nearest the line's centroid X, with ties (and near-
  ;; ties) broken by insertion order. A 2-point line has both endpoints
  ;; exactly equidistant from the centroid X; with 3+ random vertices,
  ;; FP rounding in the centroid computation occasionally flips the
  ;; tie-break between JTS and the wasmts port. The InteriorPointPoint
  ;; variant doesn't have this issue (a single Point IS its own
